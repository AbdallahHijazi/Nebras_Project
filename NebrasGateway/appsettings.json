{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "photos_post": {
        "ClusterId": "photo_new",
        "Match": { "Path": "/api/photos" }
      },
      "photo_get_by_ids": {
        "ClusterId": "photo_new",
        "Match": { "Path": "/api/photos/{schoolId}/{photoId}" }
      },
      "legacy_fallback": {
        "ClusterId": "legacy",
        "Match": { "Path": "/api/{**catch-all}" }
      }
    },
    "Clusters": {
      "photo_new": {
        "Destinations": {
          "d1": { "Address": "https://localhost:7158/" }
        }
      },
      "legacy": {
        "Destinations": {
          "d1": { "Address": "https://localhost:7177/" }
        }
      }
    }
  }
}
